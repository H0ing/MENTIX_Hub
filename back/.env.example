# Environment
NODE_ENV=development

# Server
PORT=3000

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mentix_hub

# Database Users
DB_USER_USER=mentix_user
DB_USER_PASS=user_password_here

DB_DEV_USER=mentix_dev
DB_DEV_PASS=dev_password_here

DB_ROOT_USER=root
DB_ROOT_PASS=root_password_here

# JWT Configuration
JWT_ACCESS_SECRET=your_access_secret_key_here
JWT_REFRESH_SECRET=your_refresh_secret_key_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=noreply@mentixhub.com

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=uploads